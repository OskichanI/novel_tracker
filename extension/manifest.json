{
  "manifest_version": 3,
  "name": "Novela Tracker",
  "version": "0.2",
  "permissions": ["tabs", "storage", "scripting", "alarms"],
  "host_permissions": ["http://localhost:3000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
