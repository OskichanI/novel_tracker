{
  "manifest_version": 3,
  "name": "NovelTracker",
  "version": "0.3",
  "description": "Track and save novel chapters automatically.",

  "permissions": ["activeTab", "storage", "scripting", "alarms"],

  "host_permissions": ["https://*/*", "http://*/*"],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "NovelTracker"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "noveltracker@extension",
      "strict_min_version": "109.0"
    },
    "gecko_android": {
      "strict_min_version": "113.0"
    }
  }
}
